# ============================================================
# D-Done Frontend — Environment Variables
# ============================================================
# Copy to .env.local:  cp .env.example .env.local
# ============================================================

# ---- Backend API ----
# Must match your FastAPI base path (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ---- Descope (same Project ID as backend DESCOPE_PROJECT_ID) ----
# Console: https://app.descope.com → Project settings → Project ID
NEXT_PUBLIC_DESCOPE_PROJECT_ID=
