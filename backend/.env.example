# ============================================================
# D-Done Backend — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# ============================================================

# ---- Database ----
# PostgreSQL connection string.
# Devcontainer default: postgresql://postgres:postgres@db:5432/d_done
# Local dev (native):   postgresql://postgres:postgres@localhost:5432/d_done
# SQLite fallback:      sqlite:///./dev.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/d_done

# ---- Google Cloud Platform ----
# GCP project ID (for ADC quota project).
GCP_PROJECT_ID=

# ---- Google Cloud Storage ----
# Bucket name for document uploads.
GCS_BUCKET_NAME=d-done
# Bucket region — me-west1 (Tel Aviv) for data residency.
GCS_LOCATION=me-west1

# ---- Auth ----
# Descope project ID (session JWT validation + login widget).
DESCOPE_PROJECT_ID=

# Set to true to skip cookie auth (local dev only; not allowed when K_SERVICE is set).
AUTH_DISABLED=false
# When AUTH_DISABLED=true, optional user email to impersonate; otherwise first user in DB.
# AUTH_DEV_USER_EMAIL=dev@example.com

# Comma-separated emails that are auto-approved as admin on first invite/sign-up.
# AUTH_ADMIN_EMAILS=you@example.com

# Frontend origin for invite links in emails (no trailing slash).
FRONTEND_BASE_URL=http://localhost:3000

# Resend (transactional email for invitations).
# RESEND_API_KEY=re_...
# Must be: email@verified-domain.com OR Display Name <email@verified-domain.com>
# (no smart quotes; use @d-done.com after Resend domain verification)
# EMAIL_FROM=D-Done <noreply@d-done.com>

# ---- Gemini AI ----
# Preferred: Vertex AI (google-genai + ADC)
# - Ensure you have ADC locally: `gcloud auth application-default login`
# - Set your GCP project and (optional) Vertex AI location.
#   Gemini 3 Pro is available in `global`.
VERTEX_AI_LOCATION=global

# ---- CORS ----
# Comma-separated allowed origins. Leave unset for defaults (localhost + d-done.com).
# Local dev: no need to set — default includes http://localhost:3000.
# Cloud Run: set to your frontend origin(s), e.g. https://d-done.com
# CORS_ORIGINS=https://d-done.com
